{
  "manifest_version": "0.3",
  "name": "seats-aero-pp-mcp",
  "display_name": "Seats Aero Partner",
  "version": "3.10.0",
  "description": "Seats Aero Partner API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/seats-aero-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/seats-aero-pp-mcp",
      "args": [],
      "env": {
        "SEATS_AERO_API_KEY": "${user_config.seats_aero_api_key}"
      }
    }
  },
  "user_config": {
    "seats_aero_api_key": {
      "type": "string",
      "title": "SEATS_AERO_API_KEY",
      "description": "Seats.aero Partner API key.",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
